# ── SmartFinance PTY - Variables de entorno ──────────────────────────────────
# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env al repositorio (está en .gitignore)

# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_DB=smartfinance_db
POSTGRES_USER=smartfinance
POSTGRES_PASSWORD=CAMBIA_ESTO_EN_PRODUCCION

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIA_ESTO_EN_PRODUCCION

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera uno seguro: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_EN_PRODUCCION_MINIMO_256_BITS

# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
