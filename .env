# ── SmartFinance PTY - Variables de entorno ──────────────────────────────────
# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env al repositorio (está en .gitignore)

# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_DB=smartfinance_db
POSTGRES_USER=smartfinance
POSTGRES_PASSWORD=root

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera uno seguro: openssl rand -hex 32
JWT_SECRET=df486cc38c58e60184e747b475692ba3bcc14cc4aa24f548d35a259d35493c19

# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev #produccion: prod,prod-s3, prod,prod-cloudinary

# Descomentar cuando uses S3:
# AWS_ACCESS_KEY=...
# AWS_SECRET_KEY=...
# AWS_S3_BUCKET=smartfinancepty-files
# AWS_REGION=us-east-1

# Descomentar cuando uses Cloudinary:
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
